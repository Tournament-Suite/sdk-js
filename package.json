{
  "name": "@tournamentsuite/sdk",
  "version": "1.0.0",
  "description": "Official TypeScript SDK for the Tournament Suite API",
  "main": "dist/index.js",
  "module": "dist/index.mjs",
  "types": "dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.mjs",
      "require": "./dist/index.js"
    }
  },
  "scripts": {
    "build": "tsup src/index.ts --format esm,cjs --dts",
    "dev": "tsup src/index.ts --format esm,cjs --dts --watch",
    "test": "vitest run --passWithNoTests",
    "lint": "eslint src/"
  },
  "keywords": [
    "tournamentsuite",
    "esports",
    "tournament",
    "sdk",
    "api"
  ],
  "license": "MIT",
  "homepage": "https://tournamentsuite.com/developer",
  "repository": {
    "type": "git",
    "url": "https://github.com/Tournament-Suite/sdk-js"
  },
  "dependencies": {
    "socket.io-client": "^4.8.0"
  },
  "devDependencies": {
    "@types/node": "^26.1.1",
    "@typescript-eslint/eslint-plugin": "^8.64.0",
    "@typescript-eslint/parser": "^8.64.0",
    "eslint": "^10.7.0",
    "tsup": "^8.0.0",
    "typescript": "^5.0.0",
    "vitest": "^1.0.0"
  }
}
